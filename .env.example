# NewsAPI — get your key at newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Resend — get your key at resend.com/api-keys
RESEND_API_KEY=your_resend_key_here

# Email delivery
REPORT_FROM_EMAIL=intelligence@yourdomain.com
REPORT_TO_EMAIL=you@youremail.com

# Anthropic (Claude) — for AI summarization; get at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# App settings
PORT=3000
NODE_ENV=production

# Cache settings (hours) — set to 24 for daily refresh
CACHE_TTL_HOURS=24
